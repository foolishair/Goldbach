  Classical.em _

/-- **goldbachCount n = 0 或 > 0** 平凡分类。 -/
theorem goldbachCount_dichotomy (n : ℕ) : goldbachCount n = 0 ∨ 0 < goldbachCount n := by
  rcases Nat.eq_zero_or_pos (goldbachCount n) with h | h
  · exact Or.inl h
  · exact Or.inr h

